NODE_ENV=production
PORT=3000

DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=replace-me
DB_DATABASE=9tours_db
DB_SYNCHRONIZE=false

JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
REMEMBER_ME_REFRESH_TTL_DAYS=30
AUTH_COOKIE_NAME=refresh_token
AUTH_COOKIE_DOMAIN=example.com

FRONTEND_URL=https://example.com
CORS_ORIGINS=https://example.com
BACKEND_PUBLIC_URL=https://example.com/api
UPLOADS_ROOT=/mnt/9tours-uploads

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://example.com/api/auth/google/callback

MAIL_ENABLED=false
ENABLE_TOUR_JSON_IMPORT=false
ENABLE_DEMO_DASHBOARD_SEED=false

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="9Tours Booking" <noreply@example.com>

PROMPTPAY_ID=
PROMPTPAY_ACCOUNT_NAME=

SLIP2GO_API_SECRET=
SLIP2GO_BASE_URL=https://connect.slip2go.com/api
